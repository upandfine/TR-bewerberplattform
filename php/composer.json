{
    "name": "train/bewerbermanagement-durchstich",
    "description": "Minimaler vertikaler Durchstich: Bewerbung einreichen + auflisten",
    "type": "project",
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": false
    }
}
