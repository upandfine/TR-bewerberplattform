# ============================================================
#  Zentrale Zugangsdaten für die gesamte Umgebung
#  Kopiere diese Datei nach ".env" und passe die Werte an:
#      cp .env.example .env
# ============================================================

# --- MariaDB ---------------------------------------------------
# Passwort des Datenbank-Administrators (Benutzer "root")
MARIADB_ROOT_PASSWORD=rootpass

# Datenbank, die beim ersten Start automatisch angelegt wird
MARIADB_DATABASE=bewerbung_db

# Normaler Arbeits-Benutzer (wird automatisch angelegt)
MARIADB_USER=app
MARIADB_PASSWORD=apppass

# --- Veröffentlichte Ports (Host-Seite) ------------------------
# Falls ein Port auf deinem Rechner schon belegt ist,
# einfach hier die linke Zahl ändern.
PHP_PORT=8080
PYTHON_PORT=8001
NODE_PORT=3000
PHPMYADMIN_PORT=8081
NOCODB_PORT=8090
DOTNET_PORT=8082
JAVA_PORT=8083
KOTLIN_PORT=8084
GO_PORT=8085
RUBY_PORT=8086
VUE_PORT=5173
DB_PORT=3306

# --- Tools-Container (git, curl) -------------------------------
# Werden als Autor/Committer in den Tools-Container gereicht,
# damit "git commit" einen sinnvollen Namen einsetzt.
GIT_USER_NAME=Teilnehmer
GIT_USER_EMAIL=teilnehmer@example.local
