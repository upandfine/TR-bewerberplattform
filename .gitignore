# Zugangsdaten niemals einchecken
.env

# Persistente Datenbank-Daten
db_data/

# Abhängigkeiten der App-Container
node/app/node_modules/
php/vendor/

# Python-Bytecode-Cache
__pycache__/
*.pyc

# .NET build-Output
dotnet/**/bin/
dotnet/**/obj/

# Java / Kotlin (Maven) build-Output
java/target/
java/**/target/
kotlin/target/
kotlin/**/target/
*.class

# Go (Module-Cache liegt im Container; lokales vendor/ wenn ueberhaupt)
go/vendor/

# Ruby (Bundler-Cache liegt im Container; lokales .bundle wenn ueberhaupt)
ruby/.bundle/
ruby/vendor/bundle/

# Betriebssystem-Müll
.DS_Store
Thumbs.db

# Lokale Editor-/Tool-Einstellungen
.claude/
